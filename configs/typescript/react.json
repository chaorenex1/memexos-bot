{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "types": ["react", "react-dom"]
  }
}
