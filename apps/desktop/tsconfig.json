{
  "extends": "@repo/tsconfig/react.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@main/*": ["./electron/main/*"],
      "@preload/*": ["./electron/preload/*"],
      "@ipc/*": ["./electron/ipc/*"],
      "@shared/*": ["./electron/shared/*"]
    },
    "noEmit": true,
    "types": ["vite/client", "electron-vite/node"]
  },
  "include": ["src", "electron", "electron.vite.config.ts", "tailwind.config.ts"],
  "exclude": ["node_modules", "out", "dist"]
}
