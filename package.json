{
  "name": "react-universal-electron-starter",
  "version": "0.1.0",
  "private": true,
  "description": "React + TypeScript + Vite + Electron 多端业务脚手架（PC Web / Mobile Web / Desktop）",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.10.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@app/web",
    "dev:ssr": "turbo run dev --filter=@app/web-ssr",
    "dev:desktop": "turbo run dev --filter=@app/desktop",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@app/web",
    "build:ssr": "turbo run build --filter=@app/web-ssr",
    "build:desktop": "turbo run build --filter=@app/desktop",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\" --cache",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "tsx scripts/clean.ts",
    "check-env": "tsx scripts/check-env.ts",
    "create:package": "tsx scripts/create-package.ts",
    "create:page": "tsx scripts/create-page.ts",
    "create:component": "tsx scripts/create-component.ts",
    "release": "tsx scripts/release.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^20.16.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "^7.0.3",
    "eslint": "^9.12.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  }
}
